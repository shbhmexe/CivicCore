generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  name        String?
  email       String      @unique
  image       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  karmaPoints Int         @default(0)
  password    String?
  ranking     String?
  role        Role        @default(CITIZEN)
  phoneNumber String?
  comments    Comment[]
  complaints  Complaint[]
  votes       Vote[]
  redemptions Redemption[]
  notifications Notification[]
}

model Redemption {
  id        String   @id @default(cuid())
  userId    String
  reward    String
  points    Int
  code      String?  @default("XXXX-XXXX-XXXX")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // e.g., "NEW_REPORT", "RESOLVED", "UPVOTES"
  content     String   // e.g., "🆕 New pothole reported on MG Road"
  complaintId String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model IssueVerification {
  id          String   @id @default(cuid())
  userId      String
  complaintId String
  type        String   // "VERIFY" or "IGNORE"
  createdAt   DateTime @default(now())

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  // Ensure a user can only vote once per complaint
  @@unique([userId, complaintId])
  @@index([complaintId])
}


model Department {
  id          String      @id @default(cuid())
  name        String      @unique // e.g. "Roads & Infrastructure"
  slug        String      @unique // e.g. "roads"
  email       String?     // Optional default email for the department
  phone       String?
  description String?
  complaints  Complaint[]
}

model Complaint {
  id              String    @id @default(cuid())
  title           String
  description     String
  category        String
  latitude        Float
  longitude       Float
  address         String?
  userId          String
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  images             String[]
  videoUrl           String?
  resolutionImage    String?
  severity           Severity  @default(LOW)
  status             Status    @default(PENDING)
  verificationMethod String    @default("CALL")
  isConfirmed        Boolean   @default(false)
  isEscalated        Boolean   @default(false)
  escalatedTo        String?
  escalatedAt        DateTime?
  resolutionScore    Float?
  totalVerifications Int       @default(0)
  totalIgnores       Int       @default(0)
  confidenceScore    Float     @default(0)
  escalationEmailSent Boolean  @default(false)
  
  comments           Comment[]
  user               User                @relation(fields: [userId], references: [id])
  votes              Vote[]
  issueVerifications IssueVerification[]
  
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])


  @@index([status])
  @@index([userId])
}

model Vote {
  id          String    @id @default(cuid())
  userId      String
  complaintId String
  createdAt   DateTime  @default(now())
  type        String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])


  @@unique([userId, complaintId])
}

model Comment {
  id          String    @id @default(cuid())
  complaintId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

}

enum Role {
  CITIZEN
  ADMIN
}

enum Status {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "STATUS_CHANGE", "UPVOTE", "COMMENT"
  message     String
  link        String?  // e.g. "/complaints/[id]"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}
